---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Servicios AZ Inmobiliarios | Bienes Raíces en Guatemala",
  description = "Encuentra tu próxima propiedad en venta o renta con Servicios AZ Inmobiliarios. Asesoría profesional y confiable en Guatemala.",
  image = "/images/logo-full.svg",
} = Astro.props;

const ogImageUrl = new URL(image, Astro.site).href;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" sizes="512x512" href="/images/favicon-512.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/images/favicon-192.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
  </body>
</html>