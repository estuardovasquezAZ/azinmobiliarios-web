---
// src/pages/propiedades/[id].astro
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import PropertyGallery from "../../components/PropertyGallery.astro";
import ContactForm from "../../components/ContactForm.astro";
import ShareButtons from "../../components/ShareButtons.astro";

export async function getStaticPaths() {
  const propiedades = await getCollection("propiedades");
  return propiedades.map((propiedad) => ({
    params: { id: propiedad.id },
    props: { propiedad },
  }));
}

const { propiedad } = Astro.props;
const { Content } = await render(propiedad);

const {
  titulo,
  tipo,
  tipoInmueble,
  precio,
  ubicacion,
  habitaciones,
  banos,
  parqueos,
  areaConstruccion,
  areaTerreno,
  amenidades,
  imagenPortada,
  galeria,
} = propiedad.data;

const formatoQ = new Intl.NumberFormat("es-GT", { style: "currency", currency: "GTQ", maximumFractionDigits: 0 });
const formatoUSD = new Intl.NumberFormat("en-US", { style: "currency", currency: "USD", maximumFractionDigits: 0 });

const whatsappNumber = "50256120160";
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const whatsappMessage = `Hola, me interesa la propiedad "${titulo}". ¿Podrían darme más información?`;
const whatsappLink = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(whatsappMessage)}`;
---

<Layout title={`${titulo} | Servicios AZ Inmobiliarios`} description={propiedad.data.descripcion} image={imagenPortada}>
  <main class="property">
    <div class="property__container">
      <nav class="property__breadcrumb">
        <a href="/propiedades">Propiedades</a> / <span>{titulo}</span>
      </nav>

      <PropertyGallery
        images={galeria.length > 0 ? [imagenPortada, ...galeria.filter((g) => g !== imagenPortada)] : [imagenPortada]}
        alt={titulo}
          />
          
      <div class="property__grid">
        <div class="property__main">
          <span class="property__badge">{tipo === "venta" ? "En Venta" : "En Renta"}</span>
          <h1>{titulo}</h1>
          <p class="property__location">
            📍 {ubicacion.zona ? `${ubicacion.zona}, ` : ""}{ubicacion.municipio}, {ubicacion.departamento}
          </p>

          <div class="property__features">
            {habitaciones !== undefined && <div><strong>{habitaciones}</strong><span>Habitaciones</span></div>}
            {banos !== undefined && <div><strong>{banos}</strong><span>Baños</span></div>}
            {parqueos !== undefined && <div><strong>{parqueos}</strong><span>Parqueos</span></div>}
            {areaConstruccion !== undefined && <div><strong>{areaConstruccion} m²</strong><span>Construcción</span></div>}
            {areaTerreno !== undefined && <div><strong>{areaTerreno} m²</strong><span>Terreno</span></div>}
          </div>

          <div class="property__description">
            <h2>Descripción</h2>
            <Content />
          </div>

          {amenidades.length > 0 && (
            <div class="property__amenities">
              <h2>Amenidades</h2>
              <ul>
                {amenidades.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          )}
        </div>

        <aside class="property__sidebar">
          <div class="property__price-box">
            <p class="property__price-main">{formatoQ.format(precio.quetzales)}</p>
            <p class="property__price-alt">{formatoUSD.format(precio.dolares)}</p>
            <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="property__whatsapp-btn">
              Contactar por WhatsApp
            </a>
          </div>
          <ContactForm propertyTitle={titulo} propertyUrl={canonicalUrl} />
<ShareButtons title={titulo} url={canonicalUrl} />
        </aside>
      </div>
    </div>
  </main>
</Layout>

<style>
  .property__container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.5rem;
  }

  .property__breadcrumb {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .property__breadcrumb a {
    color: var(--color-blue-medium);
  }

  .property__main-image {
    width: 100%;
    max-height: 500px;
    object-fit: cover;
    border-radius: 10px;
    margin-bottom: 1rem;
  }

  .property__thumbnails {
    display: flex;
    gap: 0.75rem;
    overflow-x: auto;
    margin-bottom: 2rem;
  }

  .property__thumbnails img {
    width: 100px;
    height: 75px;
    object-fit: cover;
    border-radius: 6px;
    flex-shrink: 0;
  }

  .property__grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 3rem;
    margin-top: 2rem;
    align-items: start;
  }

  .property__badge {
    display: inline-block;
    background-color: var(--color-blue-dark);
    color: var(--color-white);
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.3rem 0.8rem;
    border-radius: 4px;
    margin-bottom: 0.75rem;
  }

  .property__main h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .property__location {
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .property__features {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
    padding: 1.25rem 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .property__features div {
    display: flex;
    flex-direction: column;
  }

  .property__features strong {
    font-size: 1.1rem;
  }

  .property__features span {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .property__description,
  .property__amenities {
    margin-bottom: 2rem;
  }

  .property__description h2,
  .property__amenities h2 {
    font-size: 1.3rem;
    margin-bottom: 1rem;
  }

  .property__amenities ul {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.6rem;
  }

  .property__amenities li::before {
    content: "✓ ";
    color: var(--color-blue-medium);
    font-weight: 700;
  }

  .property__price-box {
    background-color: var(--color-bg-alt);
    border-radius: 10px;
    padding: 1.5rem;
    position: sticky;
    top: 90px;
  }

  .property__price-main {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-blue-dark);
  }

  .property__price-alt {
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .property__whatsapp-btn {
    display: block;
    text-align: center;
    background-color: #25d366;
    color: var(--color-white);
    font-weight: 600;
    padding: 0.9rem;
    border-radius: 6px;
  }

  .property__whatsapp-btn:hover {
    background-color: #1fb855;
  }

  @media (max-width: 768px) {
    .property__grid {
      grid-template-columns: 1fr;
    }

    .property__price-box {
      position: static;
    }
  }
  .property__description :global(p) {
    margin-bottom: 1.1rem;
  }

  .property__description :global(p:last-child) {
    margin-bottom: 0;
  }

  .property__description :global(ul),
  .property__description :global(ol) {
    margin: 0 0 1.1rem 1.25rem;
  }

  .property__description :global(strong) {
    font-weight: 600;
  }
</style>
