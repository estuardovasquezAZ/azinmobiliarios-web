---
// src/pages/blog/[id].astro
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import ShareButtons from "../../components/ShareButtons.astro";

export async function getStaticPaths() {
  const articulos = await getCollection("blog");
  return articulos.map((articulo) => ({
    params: { id: articulo.id },
    props: { articulo },
  }));
}

const { articulo } = Astro.props;
const { Content } = await render(articulo);
const { titulo, resumen, imagenPortada, autor, fechaPublicacion, tags } = articulo.data;

const fechaFormateada = new Intl.DateTimeFormat("es-GT", {
  day: "numeric",
  month: "long",
  year: "numeric",
}).format(fechaPublicacion);

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
---

<Layout title={`${titulo} | Servicios AZ Inmobiliarios`} description={resumen} image={imagenPortada}>
  <main class="article">
    <div class="article__container">
      <nav class="article__breadcrumb">
        <a href="/blog">Blog</a> / <span>{titulo}</span>
      </nav>

      <div class="article__header">
        <h1>{titulo}</h1>
        <p class="article__meta">{fechaFormateada} · {autor}</p>
      </div>

      <img src={imagenPortada} alt={titulo} class="article__cover" />

      <div class="article__content">
        <Content />
      </div>

      {tags.length > 0 && (
        <div class="article__tags">
          {tags.map((tag) => <span class="article__tag">{tag}</span>)}
        </div>
      )}

      <div class="article__share">
        <ShareButtons title={titulo} url={canonicalUrl} />
      </div>
    </div>
  </main>
</Layout>

<style>
  .article__container {
    max-width: 760px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .article__breadcrumb {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .article__breadcrumb a {
    color: var(--color-blue-medium);
  }

  .article__header h1 {
    font-size: 2.1rem;
    font-weight: 700;
    line-height: 1.25;
    margin-bottom: 0.6rem;
  }

  .article__meta {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .article__cover {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 10px;
    margin-bottom: 2rem;
  }

  .article__content {
    font-size: 1.05rem;
    line-height: 1.75;
  }

  .article__content :global(p) {
    margin-bottom: 1.25rem;
  }

  .article__content :global(p:last-child) {
    margin-bottom: 0;
  }

  .article__content :global(h2) {
    font-size: 1.4rem;
    font-weight: 700;
    margin: 2rem 0 1rem;
  }

  .article__content :global(h3) {
    font-size: 1.2rem;
    font-weight: 600;
    margin: 1.5rem 0 0.75rem;
  }

  .article__content :global(ul),
  .article__content :global(ol) {
    margin: 0 0 1.25rem 1.25rem;
  }

  .article__content :global(strong) {
    font-weight: 600;
  }

  .article__content :global(a) {
    color: var(--color-blue-medium);
    text-decoration: underline;
  }

  .article__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .article__tag {
    font-size: 0.8rem;
    background-color: var(--color-bg-alt);
    color: var(--color-text-muted);
    padding: 0.3rem 0.75rem;
    border-radius: 20px;
  }

  .article__share {
    margin-top: 1.5rem;
  }
</style>