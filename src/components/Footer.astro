  { name: "Instagram", url: "https://www.instagram.com/estuardovasquezbr/", icon: "instagram" },
  { name: "LinkedIn", url: "https://www.linkedin.com/in/estuardo-vasquez/", icon: "linkedin" },
  { name: "YouTube", url: "https://youtube.com/@estuardovasquezaz", icon: "youtube" },
