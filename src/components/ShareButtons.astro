---
// src/components/ShareButtons.astro
interface Props {
  title: string;
  url: string;
}

const { title, url } = Astro.props;

const whatsappShareText = encodeURIComponent(`Mira esta propiedad: ${title}`);
const whatsappShareUrl = `https://wa.me/?text=${whatsappShareText}%20${encodeURIComponent(url)}`;
const facebookShareUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`;
---

<div class="share">
  <span class="share__label">Compartir:</span>

  <a href={whatsappShareUrl} target="_blank" rel="noopener noreferrer" class="share__btn share__btn--whatsapp" aria-label="Compartir por WhatsApp">
    <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12.012 2c-5.506 0-9.98 4.474-9.98 9.98 0 1.76.46 3.483 1.334 5.003L2 22l5.146-1.35a9.96 9.96 0 0 0 4.865 1.24h.001c5.505 0 9.98-4.474 9.98-9.98 0-2.665-1.037-5.17-2.922-7.055A9.945 9.945 0 0 0 12.012 2zm0 18.15h-.001a8.19 8.19 0 0 1-4.174-1.142l-.3-.178-3.055.801.815-2.978-.195-.306a8.17 8.17 0 0 1-1.253-4.367c0-4.52 3.679-8.198 8.2-8.198 2.19 0 4.25.854 5.798 2.404a8.14 8.14 0 0 1 2.399 5.8c0 4.521-3.679 8.164-8.234 8.164z"/></svg>
  </a>

  <a href={facebookShareUrl} target="_blank" rel="noopener noreferrer" class="share__btn share__btn--facebook" aria-label="Compartir en Facebook">
    <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
  </a>

  <button type="button" class="share__btn share__btn--copy" id="copy-link-btn" aria-label="Copiar enlace" data-url={url}>
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 9h9a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H9a2 2 0 0 1-2-2v-9a2 2 0 0 1 2-2z"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
    <span id="copy-link-text">Copiar enlace</span>
  </button>
</div>

<style>
  .share {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  .share__label {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .share__btn {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background-color: var(--color-bg-alt);
    color: var(--color-gray-dark);
    border: none;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, width 0.2s ease;
  }

  .share__btn svg {
    flex-shrink: 0;
    margin: 0 auto;
  }

  .share__btn--whatsapp:hover {
    background-color: #25d366;
    color: var(--color-white);
  }

  .share__btn--facebook:hover {
    background-color: #1877f2;
    color: var(--color-white);
  }

  .share__btn--copy {
    width: auto;
    padding: 0 0.9rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 500;
    font-family: var(--font-body);
  }

  .share__btn--copy:hover {
    background-color: var(--color-blue-dark);
    color: var(--color-white);
  }

  .share__btn--copy.is-copied {
    background-color: #1fb855;
    color: var(--color-white);
  }
</style>

<script>
  const copyBtn = document.getElementById("copy-link-btn");
  const copyText = document.getElementById("copy-link-text");

  copyBtn?.addEventListener("click", async () => {
    const url = copyBtn.dataset.url || window.location.href;
    try {
      await navigator.clipboard.writeText(url);
      if (copyText) copyText.textContent = "¡Copiado!";
      copyBtn.classList.add("is-copied");
      setTimeout(() => {
        if (copyText) copyText.textContent = "Copiar enlace";
        copyBtn.classList.remove("is-copied");
      }, 2000);
    } catch (err) {
      console.error("No se pudo copiar el enlace", err);
    }
  });
</script>