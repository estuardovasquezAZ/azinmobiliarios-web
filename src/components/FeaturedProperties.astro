---
// src/components/FeaturedProperties.astro
import { getCollection } from "astro:content";
import PropertyCard from "./PropertyCard.astro";

const todas = await getCollection("propiedades");
const destacadas = todas
  .filter((p) => p.data.destacada)
  .sort((a, b) => b.data.fechaPublicacion.valueOf() - a.data.fechaPublicacion.valueOf())
  .slice(0, 6);
---

{destacadas.length > 0 && (
  <section class="featured">
    <div class="featured__container">
      <div class="featured__header">
        <h2>Propiedades destacadas</h2>
        <a href="/propiedades" class="featured__see-all">Ver todas →</a>
      </div>

      <div class="featured__grid">
        {destacadas.map((propiedad) => <PropertyCard propiedad={propiedad} />)}
      </div>
    </div>
  </section>
)}

<style>
  .featured {
    padding: 4rem 0;
  }

  .featured__container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .featured__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .featured__header h2 {
    font-size: 1.8rem;
    font-weight: 700;
  }

  .featured__see-all {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-blue-medium);
    white-space: nowrap;
  }

  .featured__see-all:hover {
    color: var(--color-blue-dark);
  }

  .featured__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }
</style>