---
// src/components/ContactForm.astro
interface Props {
  propertyTitle: string;
  propertyUrl: string;
}

const { propertyTitle, propertyUrl } = Astro.props;
const WEB3FORMS_KEY = "56ba5101-63a4-481d-ac89-f4a090febdee";
---

<div class="contact-form">
  <h3>¿Te interesa esta propiedad?</h3>
  <p class="contact-form__subtitle">Déjanos tus datos y te contactaremos pronto.</p>

  <form id="property-contact-form">
    <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
    <input type="hidden" name="subject" value={`Nuevo interesado: ${propertyTitle}`} />
    <input type="hidden" name="property" value={propertyTitle} />
    <input type="hidden" name="property_url" value={propertyUrl} />
    <input type="checkbox" name="botcheck" style="display:none" />

    <div class="contact-form__field">
      <label for="name">Nombre completo</label>
      <input type="text" id="name" name="name" required />
    </div>

    <div class="contact-form__field">
      <label for="email">Correo electrónico</label>
      <input type="email" id="email" name="email" required />
    </div>

    <div class="contact-form__field">
      <label for="phone">Teléfono</label>
      <input type="tel" id="phone" name="phone" required />
    </div>

    <button type="submit" class="contact-form__submit">Enviar</button>
    <p class="contact-form__status" id="form-status"></p>
  </form>
</div>

<style>
  .contact-form {
    background-color: var(--color-bg-alt);
    border-radius: 10px;
    padding: 1.5rem;
    margin-top: 1.25rem;
  }

  .contact-form h3 {
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }

  .contact-form__subtitle {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 1.25rem;
  }

  .contact-form__field {
    margin-bottom: 0.9rem;
  }

  .contact-form__field label {
    display: block;
    font-size: 0.85rem;
    font-weight: 500;
    margin-bottom: 0.35rem;
  }

  .contact-form__field input {
    width: 100%;
    padding: 0.65rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-family: var(--font-body);
    font-size: 0.95rem;
  }

  .contact-form__field input:focus {
    outline: none;
    border-color: var(--color-blue-medium);
  }

  .contact-form__submit {
    width: 100%;
    background-color: var(--color-blue-dark);
    color: var(--color-white);
    font-weight: 600;
    padding: 0.8rem;
    border-radius: 6px;
    border: none;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .contact-form__submit:hover {
    background-color: var(--color-blue-medium);
  }

  .contact-form__submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .contact-form__status {
    margin-top: 0.75rem;
    font-size: 0.9rem;
    text-align: center;
  }
</style>

<script>
  const form = document.getElementById("property-contact-form") as HTMLFormElement | null;
  const status = document.getElementById("form-status");

  if (form && status) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const submitBtn = form.querySelector("button[type=submit]") as HTMLButtonElement;
      submitBtn.disabled = true;
      submitBtn.textContent = "Enviando...";
      status.textContent = "";

      const formData = new FormData(form);

      try {
        const response = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: { Accept: "application/json" },
          body: formData,
        });
        const result = await response.json();

        if (result.success) {
          status.textContent = "¡Gracias! Te contactaremos pronto.";
          status.style.color = "#1fb855";
          form.reset();
        } else {
          throw new Error(result.message || "Error al enviar");
        }
      } catch (error) {
        status.textContent = "Hubo un error. Intenta de nuevo o contáctanos por WhatsApp.";
        status.style.color = "#e02424";
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = "Enviar";
      }
    });
  }
</script>