---
// src/components/PropertyGallery.astro
interface Props {
  images: string[];
  alt: string;
}

const { images, alt } = Astro.props;
---

<div class="gallery">
  <div class="gallery__main">
    {images.map((img, i) => (
      <img
        src={img}
        alt={`${alt} - foto ${i + 1}`}
        class="gallery__slide"
        data-index={i}
        style={i === 0 ? "" : "display:none;"}
      />
    ))}
    {images.length > 1 && (
      <>
        <button class="gallery__arrow gallery__arrow--prev" aria-label="Foto anterior">‹</button>
        <button class="gallery__arrow gallery__arrow--next" aria-label="Foto siguiente">›</button>
      </>
    )}
  </div>

  {images.length > 1 && (
    <div class="gallery__thumbnails">
      {images.map((img, i) => (
        <img
          src={img}
          alt={`Miniatura ${i + 1}`}
          class:list={["gallery__thumb", { "is-active": i === 0 }]}
          data-index={i}
        />
      ))}
    </div>
  )}
</div>

<style>
  .gallery__main {
    position: relative;
    border-radius: 10px;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    background-color: var(--color-bg-alt);
  }

  .gallery__slide {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .gallery__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: rgba(0, 0, 0, 0.45);
    color: var(--color-white);
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }

  .gallery__arrow:hover {
    background-color: rgba(0, 0, 0, 0.7);
  }

  .gallery__arrow--prev {
    left: 0.75rem;
  }

  .gallery__arrow--next {
    right: 0.75rem;
  }

  .gallery__thumbnails {
    display: flex;
    gap: 0.6rem;
    overflow-x: auto;
    margin-top: 0.75rem;
  }

  .gallery__thumb {
    width: 90px;
    height: 65px;
    object-fit: cover;
    border-radius: 6px;
    flex-shrink: 0;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.2s ease, opacity 0.2s ease;
  }

  .gallery__thumb:hover {
    opacity: 0.85;
  }

  .gallery__thumb.is-active {
    border-color: var(--color-blue-medium);
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>(".gallery").forEach((gallery) => {
    const slides = Array.from(gallery.querySelectorAll<HTMLImageElement>(".gallery__slide"));
    const thumbs = Array.from(gallery.querySelectorAll<HTMLImageElement>(".gallery__thumb"));
    const prevBtn = gallery.querySelector<HTMLButtonElement>(".gallery__arrow--prev");
    const nextBtn = gallery.querySelector<HTMLButtonElement>(".gallery__arrow--next");

    let current = 0;
    let timer: ReturnType<typeof setInterval> | undefined;
    const AUTOPLAY_MS = 5000;

    function show(index: number) {
      current = (index + slides.length) % slides.length;
      slides.forEach((s, i) => {
        s.style.display = i === current ? "" : "none";
      });
      thumbs.forEach((t, i) => t.classList.toggle("is-active", i === current));
    }

    function next() {
      show(current + 1);
    }

    function startAutoplay() {
      stopAutoplay();
      if (slides.length > 1) timer = setInterval(next, AUTOPLAY_MS);
    }

    function stopAutoplay() {
      if (timer) clearInterval(timer);
    }

    thumbs.forEach((thumb, i) => {
      thumb.addEventListener("click", () => {
        show(i);
        startAutoplay();
      });
    });

    nextBtn?.addEventListener("click", () => {
      show(current + 1);
      startAutoplay();
    });

    prevBtn?.addEventListener("click", () => {
      show(current - 1);
      startAutoplay();
    });

    gallery.addEventListener("mouseenter", stopAutoplay);
    gallery.addEventListener("mouseleave", startAutoplay);

    startAutoplay();
  });
</script>